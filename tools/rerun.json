{
  "id": "rerun",
  "name": "Rerun",
  "version": "0.21.0",
  "category": "capture",
  "description": "Multimodal data visualization for computer vision and robotics",
  "icon": "rerun.svg",
  "tags": ["visualization", "3d", "pointcloud", "logging", "robotics"],
  "install_type": "pip",
  "install_cmd": "pip install rerun-sdk",
  "version_check_cmd": "pip show rerun-sdk",
  "launch_type": "process",
  "launch_cmd": "python -m rerun",
  "stop_cmd": "pkill -f rerun",
  "stop_cmd_win": "taskkill /F /IM rerun.exe",
  "health_check": { "type": "process", "target": "rerun", "interval_ms": 5000 },
  "open_url": "http://localhost:9090",
  "docs_url": "https://rerun.io/docs",
  "github_url": "https://github.com/rerun-io/rerun"
}
