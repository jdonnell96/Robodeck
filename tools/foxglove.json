{
  "id": "foxglove",
  "name": "Foxglove Studio",
  "version": "2.5.0",
  "category": "capture",
  "description": "Robotics data visualization and debugging platform",
  "icon": "foxglove.svg",
  "tags": ["visualization", "ros", "robotics", "debugging", "mcap"],
  "install_type": "brew",
  "install_cmd": "brew install --cask foxglove-studio",
  "install_cmd_linux": "snap install foxglove-studio",
  "install_cmd_win": "winget install -e --id Foxglove.Studio",
  "version_check_cmd": "brew list --cask foxglove-studio",
  "version_check_cmd_linux": "foxglove-studio --version",
  "version_check_cmd_win": "foxglove-studio --version",
  "launch_type": "process",
  "launch_cmd": "open -a foxglove\\ studio",
  "launch_cmd_win": "foxglove-studio",
  "stop_cmd": "pkill -f foxglove",
  "stop_cmd_win": "taskkill /F /IM foxglove-studio.exe",
  "health_check": { "type": "process", "target": "foxglove", "interval_ms": 5000 },
  "open_url": "https://app.foxglove.dev",
  "docs_url": "https://docs.foxglove.dev/",
  "github_url": "https://github.com/foxglove/studio"
}
