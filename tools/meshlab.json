{
  "id": "meshlab",
  "name": "MeshLab",
  "version": "2023.12",
  "category": "capture",
  "description": "Open source mesh processing and editing tool for 3D models",
  "icon": "meshlab.svg",
  "tags": ["mesh", "3d", "processing", "editing", "pointcloud"],
  "install_type": "brew",
  "install_cmd": "brew install --cask meshlab",
  "install_cmd_linux": "apt install -y meshlab",
  "version_check_cmd": "meshlab --version",
  "launch_type": "process",
  "launch_cmd": "open -a MeshLab",
  "launch_cmd_win": "meshlab",
  "stop_cmd": "pkill -f meshlab",
  "stop_cmd_win": "taskkill /F /IM meshlab.exe",
  "health_check": { "type": "process", "target": "meshlab", "interval_ms": 5000 },
  "docs_url": "https://www.meshlab.net/#documentation",
  "github_url": "https://github.com/cnr-isti-vclab/meshlab"
}
